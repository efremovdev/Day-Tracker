# Copy to .env and fill in. Never commit the real .env.

# Telegram bot token from @BotFather.
BOT_TOKEN=123456789:ABCdef-your-token-here

# Numeric Telegram id of the (only) tracked user.
# While testing locally, set this to YOUR OWN id so the bot replies to you.
# Find your id by messaging @userinfobot on Telegram.
TRACKED_USER_ID=000000000

# Timezone for daily/weekly reports (IANA name).
TIMEZONE=Europe/Bucharest

# Path to the SQLite database file.
# Local runs: a relative path like below is fine.
# Docker/cloud: leave this as-is — docker-compose overrides it to the path on the
# persistent volume (/data/daytracker.db), so your data survives a redeploy.
DATABASE_PATH=daytracker.db

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Macro estimator backend: "gemini" (real LLM) or "fake" (offline, deterministic
# stand-in for local dev/tests — no API key needed).
MACRO_PROVIDER=gemini

# Google AI Studio API key (free tier). Required when MACRO_PROVIDER=gemini.
GEMINI_API_KEY=

# Ordered list of Gemini models to try. The estimator falls through to the next
# model when one hits its free-tier quota (HTTP 429), so listing two models gives
# more daily headroom. Comma-separated, in priority order.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash
